# Saleor API URL (required) - keep the trailing slash
NEXT_PUBLIC_SALEOR_API_URL=https://your-instance.saleor.cloud/graphql/

# Storefront URL - set on production for correct canonical URLs and OG images
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Channel slug (required) - your Saleor channel identifier
# The root "/" redirects to this channel (e.g., "/default-channel")
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# Google Analytics 4 (optional) — overrides default production ID; set in dev to test GA
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-KWEQ7ERZT6

# App token (optional) - enables multi-channel builds by discovering additional channels
# SALEOR_APP_TOKEN=

# Affiliate system
# Secret for admin API (GET/POST /api/affiliate/admin)
# AFFILIATE_ADMIN_SECRET=your-secret-here
# SQLite DB path (defaults to ./data/affiliate.db)
# AFFILIATE_DB_PATH=/app/data/affiliate.db

# COA registry base URL (required for /coa to work)
# Server-side only. The storefront fetches `${COA_REGISTRY_BASE_URL}/<token>.json`
# from the backend COA registry. No trailing slash.
# COA_REGISTRY_BASE_URL=https://api.infinitybiolabs.com/media/coa

# NCBI E-utilities API key (optional but recommended for /research-library)
# Server-side only. Without a key, NCBI rate-limits to 3 req/sec; with a key,
# 10 req/sec. Free at https://www.ncbi.nlm.nih.gov/account/settings/.
# NCBI_API_KEY=
# Friendly identifier sent to NCBI for diagnostics (recommended).
# NCBI_TOOL=infinitybio-storefront
# NCBI_EMAIL=ops@infinitybiolabs.com

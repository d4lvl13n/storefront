# Saleor API URL (required) - keep the trailing slash
NEXT_PUBLIC_SALEOR_API_URL=https://your-instance.saleor.cloud/graphql/
# Server-side Saleor URL (optional) - feed routes prefer this at runtime when set
# SALEOR_API_URL=http://api:8000/graphql/

# Storefront URL - set on production for correct canonical URLs and OG images
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
# Server-side public storefront URL (optional) - feed routes prefer this at runtime when set
# STOREFRONT_URL=https://www.example.com

# Channel slug (required) - your Saleor channel identifier
# The root "/" redirects to this channel (e.g., "/default-channel")
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# Google Tag Manager (optional) — overrides default production container; set in dev to test GTM.
# GA4 is configured INSIDE the GTM container, so there is no separate GA measurement-ID var.
# NEXT_PUBLIC_GTM_ID=GTM-55X7GSQP

# Klaviyo (optional overrides) — public company ID drives onsite tracking + the
# newsletter signup (/api/newsletter subscribes to the list below). Defaults are
# baked in (company VQxsBE, list TUZ4vR "Email List", double opt-in).
# NEXT_PUBLIC_KLAVIYO_COMPANY_ID=VQxsBE
# KLAVIYO_NEWSLETTER_LIST_ID=TUZ4vR
# RESEND_AUDIENCE_ID is no longer used for newsletter signups (now Klaviyo).
# Klaviyo PRIVATE API key (pk_…), server-only. Enables the ORDER_PAID webhook to
# send the authoritative server-side "Placed Order" event. Unset → skipped (fail-soft).
# KLAVIYO_PRIVATE_API_KEY=

# Transactional email (Resend) — contact form, affiliate notifications, newsletter ops fallback
# RESEND_API_KEY=re_...
# Contact-form recipient (defaults to support@infinitybiolabs.com)
# CONTACT_EMAIL=support@infinitybiolabs.com
# Newsletter ops-notification recipient when Klaviyo isn't configured (falls back to CONTACT_EMAIL)
# NEWSLETTER_NOTIFY_EMAIL=ops@infinitybiolabs.com

# Saleor app token (server-side). Needs MANAGE_DISCOUNTS (affiliate voucher minting),
# MANAGE_ORDERS (track-order lookups + the Klaviyo order-line fetch), and enables
# multi-channel builds by discovering additional channels.
# SALEOR_APP_TOKEN=
# Optional channel GID fast-path for affiliate voucher minting (else resolved from slug)
# SALEOR_CHANNEL_ID=

# Catalog feeds for Google Merchant Center and Klaviyo
# FEED_CHANNEL=default-channel
# FEED_ITEM_ID_SOURCE=variant_id
# FEED_BRAND_NAME=InfinityBio
# Required to access /api/feeds/diagnostics. When unset the route returns 404 (fail-closed).
# Generate with: openssl rand -hex 32
# FEED_DIAGNOSTICS_TOKEN=
# In-process cache TTL (ms) shared by /api/feeds/google and /api/feeds/klaviyo. Default 900000 (15 min).
# FEED_CACHE_TTL_MS=900000
# How long stale catalog data may be served when a refresh fails (ms). Default 3600000 (60 min).
# FEED_STALE_TTL_MS=3600000
# Saleor GraphQL timeout per feed page (ms). Default 15000.
# FEED_GRAPHQL_TIMEOUT_MS=15000
# Hard cap on paginated feed pages (pageSize=100 each). Default 200 (=> 20,000 variants).
# FEED_MAX_PAGES=200

# Affiliate system
# Secret for admin API (GET/POST /api/affiliate/admin)
# AFFILIATE_ADMIN_SECRET=your-secret-here
# Neon Postgres connection string (injected by the Vercel/Neon integration in prod)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
# Where new-application alerts are sent (falls back to CONTACT_EMAIL, then support@)
# AFFILIATE_NOTIFY_EMAIL=ops@infinitybiolabs.com
# Operator emails allowed into /affiliate/admin (comma-separated, must match Saleor accounts)
# AFFILIATE_ADMIN_EMAILS=you@example.com,ops@example.com
# HMAC secret for the Saleor affiliate webhook (/api/affiliate/webhook). The same
# endpoint handles ORDER_PAID (record commission) and ORDER_REFUNDED /
# ORDER_FULLY_REFUNDED / ORDER_CANCELLED (reverse it); register all of them in
# Saleor and ensure the subscription selects `userEmail`.
# SALEOR_WEBHOOK_SECRET=your-webhook-secret

# Cache revalidation webhook (/api/revalidate)
# Static-secret fallback checked (as the x-revalidate-secret header) when the
# Saleor HMAC signature is absent.
# REVALIDATE_SECRET=

# Site-wide maintenance takedown — set to "1" to rewrite every page to /maintenance
# MAINTENANCE_MODE=

# COA registry base URL (required for /coa to work)
# Server-side only. The storefront fetches `${COA_REGISTRY_BASE_URL}/<token>.json`
# from the backend COA registry. No trailing slash.
# COA_REGISTRY_BASE_URL=https://api.infinitybiolabs.com/media/coa

# NCBI E-utilities API key (optional but recommended for /research-library)
# Server-side only. Without a key, NCBI rate-limits to 3 req/sec; with a key,
# 10 req/sec. Free at https://www.ncbi.nlm.nih.gov/account/settings/.
# NCBI_API_KEY=
# Friendly identifier sent to NCBI for diagnostics (recommended).
# NCBI_TOOL=infinitybio-storefront
# NCBI_EMAIL=ops@infinitybiolabs.com

# ── Advanced / tuning (optional) ──────────────────────────────────
# Saleor GraphQL client throttle + timeout (defaults are sensible for prod)
# SALEOR_MAX_CONCURRENT_REQUESTS=
# SALEOR_MIN_REQUEST_DELAY_MS=
# SALEOR_REQUEST_TIMEOUT_MS=
# Path override for the Saleor schema used by codegen
# SALEOR_SCHEMA_PATH=
# Retry count for the Docker/CI `next build` wrapper
# NEXT_BUILD_RETRIES=
# Verbose cache-tag logging in the revalidate route
# DEBUG_CACHE=

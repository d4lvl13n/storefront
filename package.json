{
	"name": "infinitybio-storefront",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"license": "SEE LICENSE IN LICENSE",
	"scripts": {
		"dev": "next dev",
		"dev:webpack": "next dev --webpack",
		"dev:turbopack": "next dev --turbopack",
		"build": "next build --webpack",
		"start": "next start",
		"predev": "node scripts/generate-all-if-possible.mjs",
		"prebuild": "node scripts/generate-all-if-possible.mjs",
		"lint": "eslint",
		"lint:fix": "eslint --fix",
		"generate": "graphql-codegen --config .graphqlrc.ts",
		"generate:checkout": "graphql-codegen --config src/checkout/graphql/codegen.ts",
		"generate:all": "pnpm run generate && pnpm run generate:checkout",
		"generate:verify": "pnpm run generate:all",
		"test": "vitest",
		"test:run": "vitest run",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"quality:gate": "pnpm exec tsc --noEmit && pnpm run test:run && pnpm run build",
		"knip": "knip",
		"prepare": "husky install"
	},
	"dependencies": {
		"@graphql-typed-document-node/core": "3.2.0",
		"@headlessui/react": "1.7.18",
		"@neondatabase/serverless": "1.1.0",

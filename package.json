		"lodash-es": "4.18.1",
		"lucide-react": "0.358.0",
		"next": "16.2.9",
		"next-themes": "0.4.6",
		"react": "^19.1.2",
		"react-dom": "^19.1.2",
		"react-error-boundary": "4.0.13",
		"server-only": "0.0.1",
		"sharp": "0.33.2",
		"tailwind-merge": "3.4.0",
		"ts-invariant": "0.10.3",
		"urql": "4.0.6",
		"xss": "1.0.15",
		"zod": "4.3.6"
	},

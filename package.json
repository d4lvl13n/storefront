			"dset": ">=3.1.4",
			"micromatch": ">=4.0.8",
			"@babel/runtime": ">=7.26.10",
			"@babel/helpers": ">=7.26.10",
			"brace-expansion@<1.1.13": "1.1.13",
			"brace-expansion@>=2": "2.0.3",
			"shell-quote": "1.8.4",
			"minimatch@<3.1.4": "3.1.4",
			"minimatch@>=9.0.0 <9.0.7": "9.0.7",

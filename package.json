		"@types/node": "20.10.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"autoprefixer": "10.4.23",
		"eslint": "9.39.1",
		"eslint-config-next": "16.0.7",
		"husky": "8.0.3",
		"knip": "5.41.1",
